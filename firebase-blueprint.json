{
  "entities": {
    "Stats": {
      "title": "Application Statistics",
      "description": "Global counters for the application",
      "type": "object",
      "properties": {
        "totalUsers": {
          "type": "number"
        },
        "totalPresentations": {
          "type": "number"
        }
      },
      "required": ["totalUsers", "totalPresentations"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Authenticated user information",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "uid": { "type": "string" },
        "createdDate": { "type": "string", "format": "date-time" },
        "pptCount": { "type": "number" }
      },
      "required": ["email", "uid", "createdDate", "pptCount"]
    },
    "PresentationMetadata": {
      "title": "Presentation Metadata",
      "description": "Record of a generated presentation",
      "type": "object",
      "properties": {
        "topic": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "slideCount": { "type": "number" },
        "complexity": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["topic", "date", "slideCount", "complexity", "userId"]
    }
  },
  "firestore": {
    "stats/counters": {
      "schema": "Stats",
      "description": "Global statistics"
    },
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile and usage stats"
    },
    "users/{userId}/presentations/{pptId}": {
      "schema": "PresentationMetadata",
      "description": "Logs of presentations generated by the user"
    }
  }
}
